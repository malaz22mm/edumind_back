# =============================================================================
# EduMinds — Environment Configuration
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# --- Application ---
APP_NAME=EduMinds
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Use "cache" on Vercel/serverless (file driver is not persistent)
APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# --- Logging (use stderr on Vercel) ---
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# --- Database (required: external MySQL or PostgreSQL on Vercel) ---
# SQLite is for local development only — it will NOT work on Vercel.
DB_CONNECTION=mysql
DB_HOST=mysql.railway.internal
DB_PORT=3306
DB_DATABASE=railway
DB_USERNAME=root
DB_PASSWORD=GuOixseyusXAgAahSXuVWLKZFusjGPpZ
# DB_URL=mysql://user:pass@host:3306/database
# DB_SSLMODE=prefer
# MYSQL_ATTR_SSL_CA=

# --- Session (database or redis recommended for production) ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=
SESSION_SAME_SITE=lax

# --- Cache (database or redis recommended for production) ---
CACHE_STORE=database
# CACHE_PREFIX=

# --- Queue (use sync on Vercel — no background workers) ---
QUEUE_CONNECTION=sync

# --- Broadcasting ---
BROADCAST_CONNECTION=log

# --- Filesystem (use s3 on Vercel for uploads) ---
FILESYSTEM_DISK=local
AVATAR_DISK=public

# --- AWS / S3 (required on Vercel for avatar uploads) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Redis (optional, for cache/session/queue at scale) ---
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_URL=

# --- Memcached (optional) ---
MEMCACHED_HOST=127.0.0.1

# --- Mail ---
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Sanctum (API token auth) ---
# Comma-separated domains for SPA cookie auth. Include your Vercel domain.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000
SANCTUM_TOKEN_PREFIX=

# --- Frontend (optional, for CORS / SPA integration) ---
FRONTEND_URL=

# --- Vercel (set automatically by Vercel; do not set locally) ---
# VERCEL=1

# --- Vite ---
VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# VERCEL DEPLOYMENT CHECKLIST
# Set these in the Vercel project dashboard (Settings → Environment Variables):
#
# Required:
#   APP_KEY              php artisan key:generate --show
#   APP_URL              https://your-app.vercel.app
#   DB_CONNECTION        mysql or pgsql
#   DB_HOST              external database host
#   DB_PORT              3306 (mysql) or 5432 (pgsql)
#   DB_DATABASE          database name
#   DB_USERNAME          database user
#   DB_PASSWORD          database password
#
# Recommended for production:
#   APP_ENV=production
#   APP_DEBUG=false
#   LOG_CHANNEL=stderr
#   LOG_LEVEL=error
#   SESSION_DRIVER=database
#   CACHE_STORE=database
#   QUEUE_CONNECTION=sync
#   FILESYSTEM_DISK=s3
#   AVATAR_DISK=s3
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY, AWS_BUCKET, AWS_DEFAULT_REGION
#   SANCTUM_STATEFUL_DOMAINS=your-frontend.vercel.app
#
# After first deploy, run migrations against your external database:
#   php artisan migrate --force
# =============================================================================
